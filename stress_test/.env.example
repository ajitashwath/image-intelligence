# stress_test/.env.example
# ──────────────────────────────────────────────────────────────────────────────
# Environment variables required by stress_test/stress_test.py
#
# Copy this file and fill in real values after running `cdk deploy`:
#   cp stress_test/.env.example stress_test/.env
#
# The .env file is gitignored — never commit real bucket names or URLs.
#
# Where to get each value:
#   S3_BUCKET_NAME  → CDK output "RawImageBucketName"
#                     or: aws cloudformation describe-stacks \
#                           --stack-name BackendStack \
#                           --query "Stacks[0].Outputs[?OutputKey=='RawImageBucketName'].OutputValue" \
#                           --output text
#
#   API_BASE_URL    → CDK output "ApiGatewayUrl"
#                     or: the VITE_API_URL GitHub secret (same value)
#
#   TABLE_NAME      → CDK output "DynamoTableName"
#                     or: aws cloudformation describe-stacks \
#                           --stack-name BackendStack \
#                           --query "Stacks[0].Outputs[?OutputKey=='DynamoTableName'].OutputValue" \
#                           --output text
# ──────────────────────────────────────────────────────────────────────────────

S3_BUCKET_NAME=your-raw-image-bucket-name
API_BASE_URL=https://xxxx.execute-api.us-east-1.amazonaws.com/prod
TABLE_NAME=BackendStack-ImageMetadataTable-XXXXXXXXXXXX
