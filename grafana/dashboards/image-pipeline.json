{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "row", "name": "Row", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "End-to-end infrastructure monitor for the Event-Driven Image Intelligence pipeline: Lambda, SQS, DynamoDB, and API Gateway metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    // =========================================================================
    // ROW 1 — Lambda Functions
    // =========================================================================
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Lambda Functions",
      "type": "row"
    },

    // Panel 2 — Total Invocations (stat)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 5000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Orchestrator Invocations",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${orchestrator_function}" },
          "expression": "",
          "id": "t1",
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "Invocations",
          "metricQueryType": 0,
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Notifier Invocations",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${notifier_function}" },
          "expression": "",
          "id": "t2",
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "Invocations",
          "metricQueryType": 0,
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Dashboard Invocations",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${dashboard_function}" },
          "expression": "",
          "id": "t3",
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "Invocations",
          "metricQueryType": 0,
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "C",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "expression": "SUM([t1, t2, t3])",
          "hide": false,
          "id": "totalInvocations",
          "refId": "D"
        }
      ],
      "title": "Total Lambda Invocations",
      "type": "stat"
    },

    // Panel 3 — Lambda Invocations by Function (time series)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "Invocations",
            "axisPlacement": "auto",
            "barAlignment": 0,
            "drawStyle": "line",
            "fillOpacity": 10,
            "gradientMode": "none",
            "hideFrom": { "legend": false, "tooltip": false, "viz": false },
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 5,
            "scaleDistribution": { "type": "linear" },
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "id": 3,
      "options": {
        "legend": { "calcs": ["sum", "mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "alias": "Orchestrator",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${orchestrator_function}" },
          "metricName": "Invocations",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Notifier",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${notifier_function}" },
          "metricName": "Invocations",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Dashboard",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${dashboard_function}" },
          "metricName": "Invocations",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "C",
          "region": "us-east-1",
          "statistic": "Sum"
        }
      ],
      "title": "Lambda Invocations by Function",
      "type": "timeseries"
    },

    // Panel 4 — Lambda Duration P95 (time series)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "alias": "Orchestrator P95",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${orchestrator_function}" },
          "metricName": "Duration",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "p95"
        },
        {
          "alias": "Notifier P95",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${notifier_function}" },
          "metricName": "Duration",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "p95"
        },
        {
          "alias": "Dashboard P95",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${dashboard_function}" },
          "metricName": "Duration",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "C",
          "region": "us-east-1",
          "statistic": "p95"
        }
      ],
      "title": "Lambda Duration P95 (ms)",
      "type": "timeseries"
    },

    // Panel 5 — Lambda Error Rate % (stat)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "percent",
          "max": 100,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Errors",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": {},
          "expression": "100 * (SUM(SEARCH('MetricName=\"Errors\" Namespace=\"AWS/Lambda\"', 'Sum', 300))) / MAX(1, SUM(SEARCH('MetricName=\"Invocations\" Namespace=\"AWS/Lambda\"', 'Sum', 300)))",
          "id": "errorRate",
          "matchExact": false,
          "metricEditorMode": 1,
          "metricQueryType": 1,
          "namespace": "AWS/Lambda",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1"
        }
      ],
      "title": "Lambda Error Rate (%)",
      "type": "stat"
    },

    // Panel 6 — Lambda Throttles (stat)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 5 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Orchestrator Throttles",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${orchestrator_function}" },
          "metricName": "Throttles",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Notifier Throttles",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${notifier_function}" },
          "metricName": "Throttles",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Dashboard Throttles",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "FunctionName": "${dashboard_function}" },
          "metricName": "Throttles",
          "namespace": "AWS/Lambda",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "C",
          "region": "us-east-1",
          "statistic": "Sum"
        }
      ],
      "title": "Lambda Throttles",
      "type": "stat"
    },

    // =========================================================================
    // ROW 2 — SQS Queues
    // =========================================================================
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 },
      "id": 7,
      "title": "SQS Queues",
      "type": "row"
    },

    // Panel 8 — TaskQueue Depth (stat)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 14 },
      "id": 8,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Task Queue Depth",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "QueueName": "${task_queue_name}" },
          "metricName": "ApproximateNumberOfMessagesVisible",
          "namespace": "AWS/SQS",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Maximum"
        }
      ],
      "title": "TaskQueue Depth",
      "type": "stat"
    },

    // Panel 9 — DLQ Depth (stat, alert threshold 1)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "color": "green", "index": 0, "text": "Empty" } }, "type": "value" }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 14 },
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "DLQ Depth",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "QueueName": "${dlq_name}" },
          "metricName": "ApproximateNumberOfMessagesVisible",
          "namespace": "AWS/SQS",
          "period": "60",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Maximum"
        }
      ],
      "title": "DLQ Depth ⚠ (alert ≥ 1)",
      "type": "stat"
    },

    // Panel 10 — SQS Messages Sent / Received (time series)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" }
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "id": 10,
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "alias": "Messages Sent",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "QueueName": "${task_queue_name}" },
          "metricName": "NumberOfMessagesSent",
          "namespace": "AWS/SQS",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Messages Received",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "QueueName": "${task_queue_name}" },
          "metricName": "NumberOfMessagesReceived",
          "namespace": "AWS/SQS",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        }
      ],
      "title": "SQS Messages Sent / Received",
      "type": "timeseries"
    },

    // =========================================================================
    // ROW 3 — DynamoDB
    // =========================================================================
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 11,
      "title": "DynamoDB",
      "type": "row"
    },

    // Panel 12 — DynamoDB Read/Write Consumed Capacity (stat)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 23 },
      "id": 12,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "Read Capacity Units",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "TableName": "${dynamodb_table}" },
          "metricName": "ConsumedReadCapacityUnits",
          "namespace": "AWS/DynamoDB",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Write Capacity Units",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "TableName": "${dynamodb_table}" },
          "metricName": "ConsumedWriteCapacityUnits",
          "namespace": "AWS/DynamoDB",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        }
      ],
      "title": "DynamoDB Consumed Capacity (RCU / WCU)",
      "type": "stat"
    },

    // Panel 13 — DynamoDB Throttled Requests (time series)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 23 },
      "id": 13,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "targets": [
        {
          "alias": "Read Throttles",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "TableName": "${dynamodb_table}" },
          "metricName": "ReadThrottleEvents",
          "namespace": "AWS/DynamoDB",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "Sum"
        },
        {
          "alias": "Write Throttles",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "TableName": "${dynamodb_table}" },
          "metricName": "WriteThrottleEvents",
          "namespace": "AWS/DynamoDB",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "Sum"
        }
      ],
      "title": "DynamoDB Throttled Requests",
      "type": "timeseries"
    },

    // =========================================================================
    // ROW 4 — API Gateway
    // =========================================================================
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 14,
      "title": "API Gateway",
      "type": "row"
    },

    // Panel 15 — API Gateway 4xx + 5xx errors (time series)
    {
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "lineWidth": 1,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "5xx Errors" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx Errors" },
