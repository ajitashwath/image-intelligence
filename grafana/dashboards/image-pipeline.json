          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "B",
          "region": "us-east-1",
          "statistic": "p99"
        }
      ],
      "title": "API Gateway Latency P99 (ms)",
      "type": "timeseries"
    }

