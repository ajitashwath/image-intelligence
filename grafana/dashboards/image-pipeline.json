      "options": {
        "legend": { "calcs": ["mean", "max", "p99"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "alias": "Latency P99",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "dimensions": { "ApiName": "${api_name}" },
          "metricName": "Latency",
          "namespace": "AWS/ApiGateway",
          "period": "$__interval",
          "queryMode": "Metrics",
          "refId": "A",
          "region": "us-east-1",
          "statistic": "p99"
        },
        {
          "alias": "Integration Latency P99",
