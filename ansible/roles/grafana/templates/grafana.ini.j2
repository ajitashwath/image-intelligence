[server]
protocol    = http
http_addr   =
http_port   = {{ grafana_port }}

enable_gzip = false

[database]
type = sqlite3
path = grafana.db

[security]
admin_user         = admin
admin_password     = {{ grafana_admin_password }}

cookie_secure      = false
cookie_samesite    = lax

allow_embedding    = false

[users]
allow_sign_up        = false
allow_org_create     = false

auto_assign_org      = true
auto_assign_org_role = Viewer

[auth]

login_maximum_inactive_lifetime_duration = 7d
login_maximum_lifetime_duration          = 30d

[auth.anonymous]
enabled = false

[auth.basic]
enabled = true

[smtp]
enabled = false

[alerting]
enabled          = true
execute_alerts   = true

notification_timeout_seconds = 30

[unified_alerting]
enabled = true

[log]
mode  = console
level = warn

[metrics]
enabled         = true
interval_seconds = 10

[analytics]
reporting_enabled    = false
check_for_updates    = false
check_for_plugin_updates = false

[plugins]
allow_loading_unsigned_plugins = grafana-cloudwatch-datasource
